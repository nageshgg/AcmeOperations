# Copy this file to .env and fill in real values. Never commit .env.

# --- PostgreSQL ---
POSTGRES_USER=acme_admin
POSTGRES_PASSWORD=changeme_dev_password
POSTGRES_DB=acme_operations
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_dev_password
# Internal (container-to-container) issuer URL. Set precisely in Step 3 to avoid
# the classic localhost-vs-keycloak:8080 issuer mismatch between browser and API.
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_REALM=acme-operations

# --- LLM provider ---
# Using Google Gemini (free tier) instead of the Anthropic API for this assessment.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- App / MCP ports ---
APP_PORT=8000
MCP_SERVER_PORT=8001
