# Copy this file to .env and fill in real values. Never commit .env.

# --- PostgreSQL ---
POSTGRES_USER=acme_admin
POSTGRES_PASSWORD=changeme_dev_password
POSTGRES_DB=acme_operations
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_dev_password
KEYCLOAK_REALM=acme-operations
KEYCLOAK_CLIENT_ID=acme-app
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
KEYCLOAK_ISSUER=http://localhost:8080/realms/acme-operations

# Dev-only test credentials seeded via keycloak/realm-export.json, one per
# RBAC role. Never reuse these outside local development.
#   sales_user   / SalesUser123!
#   support_user / SupportUser123!
#   admin        / AdminUser123!

# --- LLM provider ---
# Using Google Gemini (free tier) instead of the Anthropic API for this assessment.
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- LangSmith tracing (bonus observability, optional) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=acme-operations

# --- App / MCP ports ---
APP_PORT=8000
MCP_SERVER_PORT=8001
MCP_SERVER_URL=http://mcp-server:8001/mcp
